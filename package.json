{
  "name": "testgenai",
  "version": "1.0.0",
  "description": "AI-Powered API Testing & Validation Platform",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "node --watch server/index.js",
    "client:dev": "vite",
    "client:build": "vite build",
    "client:preview": "vite preview",
    "build": "npm run client:build",
    "start": "node server/index.js",
    "lint": "eslint src server",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "API",
    "Testing",
    "AI",
    "Gemini",
    "Cloud Run"
  ],
  "author": "TestGenAI Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "firebase-admin": "^11.11.1",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.0",
    "uuid": "^9.0.1",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.0",
    "morgan": "^1.10.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/cors": "^2.8.17",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "concurrently": "^8.2.2",
    "vite": "^5.0.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@mui/material": "^5.14.14",
    "@mui/icons-material": "^5.14.14",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "react-router-dom": "^6.20.1",
    "axios": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
